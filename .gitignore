# Evaluator outputs — regenerated by running evaluator.py.
# Keep the directories (via .gitkeep) but not the artefacts inside.
logs/*.json
logs/*.txt
logs/*.pgn
!logs/.gitkeep
experiments/*
!experiments/.gitkeep

# results.csv IS checked in (it's the durable append-only log).
# best_config.yaml IS checked in (it's the promoted best config).
